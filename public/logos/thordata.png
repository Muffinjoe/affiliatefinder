          <span class="line-number" data-v-7c13278a>2</span>
          <span class="code-lines" data-v-7c13278a><span class="token keyword">using</span> System.Collections.Generic;</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>3</span>
          <span class="code-lines" data-v-7c13278a><span class="token keyword">using</span> System.Net.Http;</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>4</span>
          <span class="code-lines" data-v-7c13278a><span class="token keyword">using</span> System.Threading.Tasks;</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>5</span>
          <span class="code-lines" data-v-7c13278a><span class="token keyword">class</span> <span class="token variable">Program</span></span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>6</span>
          <span class="code-lines" data-v-7c13278a>{</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>7</span>
          <span class="code-lines" data-v-7c13278a>    <span class="token keyword">static</span> <span class="token keyword">async</span> <span class="token builtin">Task</span> <span class="token function">Main</span>(<span class="token keyword">string</span>[] args)</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>8</span>
          <span class="code-lines" data-v-7c13278a>    {</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>9</span>
          <span class="code-lines" data-v-7c13278a>        <span class="token keyword">var</span> <span class="token variable">client</span> = <span class="token keyword">new</span> <span class="token function">HttpClient</span>();</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>10</span>
          <span class="code-lines" data-v-7c13278a>        <span class="token keyword">var</span> <span class="token variable">request</span> = <span class="token keyword">new</span> <span class="token function">HttpRequestMessage</span>(</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>11</span>
          <span class="code-lines" data-v-7c13278a>            HttpMethod.Post, </span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>12</span>
          <span class="code-lines" data-v-7c13278a>            <span class="token string">&quot;https://scraperapi.thordata.com/request&quot;</span></span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>13</span>
          <span class="code-lines" data-v-7c13278a>        );</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>14</span>
          <span class="code-lines" data-v-7c13278a>        request.Headers.<span class="token function">Add</span>(<span class="token string">&quot;Authorization&quot;</span>, <span class="token string">&quot;Bearer Token&quot;</span>);</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>15</span>
          <span class="code-lines" data-v-7c13278a>        </span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>16</span>
          <span class="code-lines" data-v-7c13278a>        <span class="token keyword">var</span> <span class="token variable">formData</span> = <span class="token keyword">new</span> <span class="token builtin">Dictionary</span>&lt;<span class="token keyword">string</span>, <span class="token keyword">string</span>&gt;</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>17</span>
          <span class="code-lines" data-v-7c13278a>        {</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>18</span>
          <span class="code-lines" data-v-7c13278a>        {<span class="token string">&quot;engine&quot;</span>, <span class="token string">&quot;google&quot;</span>},</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>19</span>
          <span class="code-lines" data-v-7c13278a>        {<span class="token string">&quot;q&quot;</span>, <span class="token string">&quot;pizza&quot;</span>},</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>20</span>
          <span class="code-lines" data-v-7c13278a>        {<span class="token string">&quot;json&quot;</span>, <span class="token string">&quot;1&quot;</span>}</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>21</span>
          <span class="code-lines" data-v-7c13278a>};</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>22</span>
          <span class="code-lines" data-v-7c13278a>        </span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>23</span>
          <span class="code-lines" data-v-7c13278a>        <span class="token keyword">var</span> <span class="token variable">content</span> = <span class="token keyword">new</span> <span class="token function">FormUrlEncodedContent</span>(formData);</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>24</span>
          <span class="code-lines" data-v-7c13278a>        request.Content = content;</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>25</span>
          <span class="code-lines" data-v-7c13278a>        </span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>26</span>
          <span class="code-lines" data-v-7c13278a>        <span class="token keyword">var</span> <span class="token variable">response</span> = <span class="token keyword">await</span> client.<span class="token function">SendAsync</span>(request);</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>27</span>
          <span class="code-lines" data-v-7c13278a>        response.<span class="token function">EnsureSuccessStatusCode</span>();</span>
        </div><div class="code-lines-wrapper lang-csharp" data-v-7c13278a>
          <span class="line-number" data-v-7c13278a>28</span>
          <span class="code-lines" data-v-7c13278a>        Console.<span class="token function">WriteLine</span>(<span class="token keyword">await</span> response.Content.<span class="token function">ReadAsStringAsync</span>());</span>
