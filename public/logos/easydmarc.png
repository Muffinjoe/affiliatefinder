        try {
            const payload = JSON.parse(atob(response.credential.split('.')[1]));
            const email = payload.email;

            const keycloakUrl = 'https://uac.easydmarc.com/realms/easydmarc';
            const clientId = 'dmarc-app';
            const redirectUri = encodeURIComponent('https://app.easydmarc.com');

