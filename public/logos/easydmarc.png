-scanner-result-box"><div class="domain-scanner-result__graph-box js-domain-scanner-result__card gap-2 gap-sm-0"><p class="js-dkim-title fs-400 fw-bold text-main mb-0"> DKIM </p><p class="text-lighter fs-100 mb-0"> DomainKeys <br/> Identified Mail </p></div></div>  </div></div><div class="js-card js-invalid invalid-card d-none mx-auto mb-2"><img src="/img/status-invalid.svg" loading="lazy" width="86" height="21" alt="Invalid"></div><div class="js-card js-undetected invalid-card d-none mx-auto mb-2"><img src="/img/status-undetected.svg" loading="lazy" width="86" height="21" alt="Undetected"></div><div class="js-card js-warning warning-card d-none mx-auto mb-2"><img src="/img/status-warning.svg" loading="lazy" width="86" height="21" alt="Warning"></div><div class="js-card js-valid valid-card d-none mx-auto mb-2"><img src="/img/status-valid.svg" loading="lazy" width="86" height="21" alt="Valid"></div></div><div class="domain-scanner-card__footer"><div class="domain-scanner-card__footer--dark-mode d-flex flex-column flex-md-row-reverse flex-md-row justify-content-between align-items-center w-100 gap-3"><div class="d-flex flex-column flex-md-row-reverse flex-md-row justify-content-between align-items-center gap-3"><a href="https://app.easydmarc.com/login" class="js-mixpanel-btn-click-event fade-in eas-button eas-button--primary eas-button--sm-full-width gtm-homepage-domain-scanner-widget-get-started" target="_blank" data-button-name="Start DMARC Journey"><span class="js-submit-text">Fix My Domain Now</span> </a><button type="submit" class="c-domain-scanner-open-modal c-open-modal js-details-btn eas-button eas-button--secondary eas-button--icon eas-button--sm-full-width" data-modal-class="js-get-report-modal" data-bs-toggle="modal" data-bs-target="#reportModal" data-action-url="https://app.easydmarc.com" data-reload="true" data-modal="js-get-report-modal" href="https://easydmarc.com/tools/domain-scanner">Send Me Full Report</button></div><a href="https://easydmarc.com/tools/domain-scanner" class="js-details-btn js-mixpanel-btn-click-event eas-button eas-button--tertiary fade-in gtm-homepage-domain-scanner-widget-show-details" target="_blank" data-button-name="See Details">See Details</a></div><script>window.addEventListener('message', (e) => {
                            if (e.data.key === `openModal` && e.data?.modal === 'js-get-report-modal') {
                                const modal = document.querySelector('.js-get-report-modal');
                                if(modal){
                                    $(modal).modal('show');
                                }
                            }
