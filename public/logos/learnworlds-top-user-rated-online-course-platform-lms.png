                var r = document.querySelectorAll(t);
                if (null !== r) {
                    if (void 0 === r.length) {
                        r.value = e[a];
                    } else {
                        for (var o = 0; o < r.length; o++) {
                            r[o].value = e[a];
                        }
                    }
