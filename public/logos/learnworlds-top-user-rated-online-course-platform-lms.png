<section class="lw-sect lw-size-m lw-align-l pt-5rem-below-768 pb-5rem-below-768">
    <div class="lw-sect-content wide">

        <h2 class="small lw-align-c ml-auto mr-auto">Craft Learning Experiences your Customers will love</h2>

        <div class="lw-cols mt-10rem mt-5rem-below-768 stretch multiple-rows small-gutters valign-center mb-0">

            <div class="col span_6_of_12 mb-0 flex-item span_12-below-768 hide-769_960">

                <img loading="lazy" class="w-full hide-above-768 mb-5rem-below-768" src="https://www.learnworlds.com/app/themes/learnworlds/assets/images/mobile-fallback/home-2-mob.webp">

                <div class="mb-3rem">
                    <h3 class="mb-1rem">Engaging and effective training</h3>
                    <div class="lw-txt lw-txt-m lw-text-color-fadeout20 mb-0">Engage learners with interactive videos, ebooks, 1:1 & group sessions, assessments, certificates, SCORMs, surveys, and much more.</div>
                </div>
                <div class="mb-3rem">
                    <h3 class="mb-1rem">The most versatile course experience</h3>
                    <div class="lw-txt lw-txt-m lw-text-color-fadeout20 mb-0">Beautiful themes for your course player and flexibility for free, paid, private, drip-fed or curated course pathways.</div>
                </div>
                <div class="mb-3rem">
                    <h3 class="mb-1rem">Re-imagined interactive video learning</h3>
                    <div class="lw-txt lw-txt-m lw-text-color-fadeout20 mb-0">Effortlessly convert your videos into exceptional experiences with automatically extracted transcripts, quizzes, and tables of contents.</div>
                </div>
                <div class="mb-3rem">
                    <h3 class="mb-1rem">Get social media talking</h3>
                    <div class="lw-txt lw-txt-m lw-text-color-fadeout20 mb-0">Nurture your community and create lasting relationships with a social-first training school.</div>
