            }
        }
        
        function initGaconnector() {
            if (typeof gaconnector !== 'undefined' && gaconnector.setCallback) {
                gaconnector.setCallback(setGaconnectorHiddenFields);
                setInterval(setGaconnectorHiddenFields, 1e3);
