        <!-- Recaptcha - Deferred loading -->
    <script data-cookieconsent="ignore">
    (function() {
        var recaptchaLoaded = false;
        var recaptchaSiteKey = '6LdkLvgZAAAAAF608MxlBReg6OurlzFAPD2QJaRF';
        
        function loadRecaptcha() {
            if (recaptchaLoaded || typeof grecaptcha !== 'undefined') {
                return;
            }
            recaptchaLoaded = true;
            var script = document.createElement('script');
            script.async = true;
            script.src = 'https://www.google.com/recaptcha/api.js?render=' + recaptchaSiteKey;
            script.setAttribute('data-cookieconsent', 'ignore');
            document.head.appendChild(script);
        }
        
        // Check if forms that need reCAPTCHA are present
        function hasRecaptchaForms() {
            return document.querySelector('.js-demo-form, .js-lead-form, form[name="corporate_form"]') !== null;
        }
        
        // Load on user interaction
        var interactionEvents = ['scroll', 'touchstart', 'mousedown', 'focus'];
        var interactionHandler = function() {
            if (hasRecaptchaForms()) {
                loadRecaptcha();
                interactionEvents.forEach(function(event) {
                    document.removeEventListener(event, interactionHandler, {passive: true});
                });
            }
        };
        
        interactionEvents.forEach(function(event) {
            document.addEventListener(event, interactionHandler, {passive: true, once: true});
        });
        
        // Fallback: load after DOM is ready if forms are present
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                if (hasRecaptchaForms()) {
                    // Small delay to prioritize user interaction
                    setTimeout(loadRecaptcha, 2000);
                }
            });
        } else {
            if (hasRecaptchaForms()) {
                setTimeout(loadRecaptcha, 2000);
            }
        }
        
        // Expose loadRecaptcha globally for form handlers that need it immediately
        window.lwLoadRecaptcha = loadRecaptcha;
    })();
    </script>
