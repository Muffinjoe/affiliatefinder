  <!--Website schema -->
  <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Main Page | Instapage",
  "url": "https://try.instapage.com/lp",
  "description": "Power your campaigns and turn more ad clicks into customers with personalized landing pages that are easy to build, deploy, optimize, and scale — all in one place. 14-day free trial. Cancel anytime.",
  "publisher": {
    "@type": "Organization",
    "name": "Instapage",
    "url": "https://instapage.com/"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://try.instapage.com/lp"
  },
  "image": {
    "@type": "ImageObject",
    "url": "//v.fastcdn.co/u/e6c956c2/63415095-0-Instapage-Logo---Bla.png",
    "alt": "Instapage Logo"
  },
  "mentions": [
    {
      "@type": "Thing",
      "name": "Drag & drop editor",
      "description": "Create high-performing landing pages in minutes with pixel-precise design features. Keep it simple or get creative with Javascript, HTML/CSS, or third-party scripts – all tailored to enhance your sales funnels."
    },
    {
      "@type": "Thing",
      "name": "AI content",
      "description": "Access AI in the landing page builder without interrupting your workflow, thereby optimizing your lead capture strategies. Create headlines, page text, CTAs, and page variations for A/B testing in seconds."
    },
    {
      "@type": "Thing",
      "name": "AdMap®",
      "description": "Visualize an ad campaign structure for a clear view of your campaigns, ad groups, and ads. Connect them to relevant landing pages and quickly deploy updates to ads and pages without any back and forth."
    },
    {
      "@type": "Thing",
      "name": "Analytics",
      "description": "Track page performance with heatmaps and view visitors, conversions, and conversion rates in real-time. Access data across your devices to understand user behavior and optimize campaigns."
    },
    {
      "@type": "Thing",
      "name": "A/B tests",
      "description": "Run A/B tests on both standard and AMP landing pages. Or get results faster with AI experiments that dynamically direct ad traffic to tested versions with higher performance ratings, no manual oversight needed."
    },
    {
      "@type": "Thing",
      "name": "Visual collaboration",
      "description": "Collaborate with your team on responsive design for page layout. Make real-time edits, consolidate feedback, and securely share pages with stakeholders to streamline the review and approval process."
    },
    {
      "@type": "Thing",
      "name": "Instablocks® & Global Blocks",
      "description": "Scale page creation with pre-designed individual block templates that you can customize, save, and reuse. Use Global Blocks across hundreds or thousands of pages and update them in just a click."
    },
    {
      "@type": "Thing",
      "name": "AMP & Thor Render Engine®",
      "description": "With built-in AMP support and Instapage's optimized back-end technology, you can create mobile pages that load in a blink to deliver a seamless mobile browsing experience and boost conversions."
    }
  ]
}</script>
  <!-- end Website schema -->
</head>
