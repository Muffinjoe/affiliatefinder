    overflow: hidden;
    position: relative;
    background: transparent;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: none;
  }

  .marquee-track.ready {
    animation: marquee 56s linear infinite;
  }

  .marquee-group {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    height: 100px;
    opacity: 0.7;
    transition: opacity 0.3s;
    flex-shrink: 0;
  }

  .logo-item:hover { opacity: 1; }

  .logo-item img {
    height: 58px;
    width: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .logo-item { height: 60px; }
    .logo-item img { height: 32px; }
    .marquee-wrapper {
      padding-top: 40px;
      padding-bottom: 60px;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    }
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="marquee-wrapper">
  <div class="marquee-track" id="track">
    <div class="marquee-group" id="group">
      <div class="logo-item"><img src="//v.fastcdn.co/u/e6c956c2/65386481-0-Customer-Logo-01.svg" alt="Logo 1"></div>
      <div class="logo-item"><img src="//v.fastcdn.co/u/e6c956c2/65386482-0-Customer-Logo-02.svg" alt="Logo 2"></div>
      <div class="logo-item"><img src="//v.fastcdn.co/u/e6c956c2/65386483-0-Customer-Logo-03.svg" alt="Logo 3"></div>
      <div class="logo-item"><img src="//v.fastcdn.co/u/e6c956c2/65386484-0-Customer-Logo-04.svg" alt="Logo 4"></div>
      <div class="logo-item"><img src="//v.fastcdn.co/u/e6c956c2/65386485-0-Customer-Logo-05.svg" alt="Logo 5"></div>
      <div class="logo-item"><img src="//v.fastcdn.co/u/e6c956c2/65386486-0-Customer-Logo-06.svg" alt="Logo 6"></div>
    </div>
  </div>
</div>

<script>
  const group = document.getElementById('group');
  const track = document.getElementById('track');
  track.appendChild(group.cloneNode(true));

  const imgs = track.querySelectorAll('img');
  let loaded = 0;
  function onLoad() {
    loaded++;
    if (loaded >= imgs.length) track.classList.add('ready');
  }
  imgs.forEach(img => {
    if (img.complete) onLoad();
    else { img.addEventListener('load', onLoad); img.addEventListener('error', onLoad); }
  });
</script>
  </div>
</div>

