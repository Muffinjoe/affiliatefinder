<style>
/* base */
.mobile-nav { font-family: Arial, sans-serif; }
.mobile-nav__header { display:flex; justify-content:end; align-items:center; padding:1rem; padding-top: 2rem; }
.mobile-nav__toggle { background:none; border:none; font-size:1.5rem; cursor:pointer; }

.mobile-nav__menu { 
  display:none; 
  flex-direction:column; 
  background:#ffffff; 
  height:92vh; 
  overflow-y:auto; 
  position:relative; 
}
.mobile-nav.open .mobile-nav__menu { display:flex; }

.mobile-nav__list { 
  list-style:none; 
  padding:0.4rem; 
  margin:0; 
  flex:1; 
}
.mobile-nav__item { border-bottom:1px solid #eee; }
.mobile-nav__link { 
  width:100%; 
  text-align:left; 
  padding:1rem; 
  font-weight:600; 
  display:flex; 
  justify-content:space-between; 
  align-items:center; 
  background:none; 
  border:none; 
  cursor:pointer; 
  font-size: 1rem;
}
.mobile-nav {
  width: 100vw;
  max-width: 100%;
  overflow-x: hidden;
}
.mobile-nav__link a { text-decoration:none; color:#000; }

.arrow { transition:transform .3s; }
.mobile-nav__item.open .arrow { transform:rotate(180deg); }


.mobile-submenu { display:none; flex-direction:column; padding:0 1rem 1rem; background:#fff; text-align: left;}
.mobile-submenu a { display:block; padding:.5rem 0; color:#000; text-decoration:none; }
.mobile-submenu a:hover { color:#4a34c4; }
.mobile-submenu__title { font-size:.8rem; text-transform:uppercase; color:#777; margin-top:1rem; margin-bottom:.5rem; font-weight:700; }


.mobile-submenu__highlight { background:#f1f0ff; padding:1rem; margin-top:1rem; border-radius:6px; }
.mobile-submenu__highlight img { width:100%; margin-bottom:.5rem; border-radius:4px; }

.mobile-nav__toggle {
  background:none;
  border:none;
  font-size:2rem;
  cursor:pointer;
  line-height:1;
}
.mobile-nav__footer { 
  position:sticky; 
  bottom:0; 
  left:0; 
  width:100%; 
  background:#fff; 
  padding:1rem; 
  display:flex; 
  flex-direction:column; 
  gap:.8rem; 
  z-index:1000; 
  box-shadow:0 -2px 6px rgba(0,0,0,0.08);
}
.btn-outline { 
  border:2px solid #000; 
  padding:.8rem; 
  text-align:center; 
  border-radius:25px; 
  text-decoration:none; 
  color:#000; 
  font-weight:600; 
}
.btn-primary { 
  background:#1a35d6; 
  color:#fff; 
  padding:.8rem; 
  text-align:center; 
  border-radius:25px; 
  text-decoration:none; 
  font-weight:600; 
}

.mobile-nav__menu {
  display: none;
  flex-direction: column;
  background: #ffffff;
  height: calc(100vh - 80px);
  overflow-y: auto;

  position: fixed;
  top: 80px;   
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}


.mobile-nav.open .mobile-nav__menu {
  display: flex;
}
</style>


<script>
  document.addEventListener("DOMContentLoaded", () => {
    const nav = document.querySelector(".mobile-nav");
    const toggle = nav.querySelector(".mobile-nav__toggle");
    const items = nav.querySelectorAll(".has-sub");
  
    toggle.addEventListener("click", () => {
      nav.classList.toggle("open");
  
      
      if (nav.classList.contains("open")) {
        toggle.textContent = "✕"; // X
      } else {
        toggle.textContent = "☰"; // hamburger
      }
    });
  
    items.forEach(item => {
      const btn = item.querySelector(".mobile-nav__link");
      btn.addEventListener("click", () => {
        item.classList.toggle("open");
        const submenu = item.querySelector(".mobile-submenu");
        submenu.style.display = item.classList.contains("open") ? "flex" : "none";
      });
    });
  });
  </script>
  </div>
</div>

